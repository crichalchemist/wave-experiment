# Detective LLM — environment variables
# Copy to .env.local (gitignored) and fill in real values.
# Never commit this file with real credentials.

# ---------------------------------------------------------------------------
# Inference (Ollama on L-series — OpenAI-compatible endpoint)
# ---------------------------------------------------------------------------
DETECTIVE_PROVIDER=vllm
VLLM_BASE_URL=http://localhost:11434/v1
VLLM_MODEL=deepseek-r1:7b

# ---------------------------------------------------------------------------
# Azure AI Foundry (Claude critic — constitutional critique loop)
# ---------------------------------------------------------------------------
AZURE_FOUNDRY_ENDPOINT=https://<your-resource>.services.ai.azure.com/models
AZURE_FOUNDRY_KEY=<your-key>
AZURE_FOUNDRY_MODEL=claude-sonnet-4-5

# ---------------------------------------------------------------------------
# Graph store
# ---------------------------------------------------------------------------
DETECTIVE_GRAPH_BACKEND=kuzu
DETECTIVE_KUZU_PATH=/data/detective/graph.kuzu

# ---------------------------------------------------------------------------
# Vault (Obsidian memory)
# ---------------------------------------------------------------------------
# Option A: filesystem vault (development / no Obsidian)
DETECTIVE_VAULT_PATH=/data/detective/vault

# Option B: Obsidian Local REST API (if Obsidian is running)
# OBSIDIAN_HOST=http://localhost:27123
# OBSIDIAN_API_TOKEN=<your-obsidian-api-token>